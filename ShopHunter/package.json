{
  "name": "shophunter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "db:migrate": "prisma migrate dev --name init && prisma generate",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "build": "yarn db:deploy && yarn db:generate && tsc -p tsconfig.server.json && yarn build:client",
    "build:client": "cd client && yarn build",
    "start": "node dist/server/index.js",
    "postinstall": "yarn db:deploy && yarn db:generate && tsc -p tsconfig.server.json && cd client && yarn install && yarn build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^6.16.3",
    "@prisma/client": "^6.16.3",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "prisma": "^6.16.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
